# ─────────────────────────────────────────────────────────────────────────────
# terraform.tfvars.example
# Copy to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to version control — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# GCP / Firebase identifiers
project_id          = "your-gcp-project-id"
firebase_project_id = "your-firebase-project-id"   # often same as project_id
region              = "asia-south1"

# Docker image URIs — generated by CI/CD after first `terraform apply`
# Run `terraform output artifact_registry_url` to get the base URL
backend_image  = "asia-south1-docker.pkg.dev/your-project/matdaan-mitra/backend:latest"
frontend_image = "asia-south1-docker.pkg.dev/your-project/matdaan-mitra/frontend:latest"

# Deployment config
environment   = "production"
log_level     = "INFO"
frontend_url  = "https://matdaan-mitra.web.app"
min_instances = 1
max_instances = 50

# ── Secrets (stored in Secret Manager, never in Git) ─────────────────────────

# Sarvam AI — https://sarvam.ai → API Keys
sarvam_api_key = "your-sarvam-api-key"

# Mapbox — https://account.mapbox.com → Tokens
mapbox_access_token = "pk.your-mapbox-token"

# Fernet key — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
fernet_key = "your-32-byte-fernet-key-base64-encoded="

# Firebase Admin SDK service account JSON — full file contents as a single string
# Download from: Firebase Console → Project Settings → Service Accounts → Generate key
# Then: firebase_service_account_json = file("path/to/firebase-admin.json")
firebase_service_account_json = "{\"type\":\"service_account\",\"project_id\":\"...\"}"

# Redis — use Upstash (free tier) for production: https://upstash.com
redis_url = "rediss://default:your-password@your-endpoint.upstash.io:6379"

# Vertex AI — fill in after running corpus/embed.py
vertex_ai_index_id          = "your-vertex-ai-index-id"
vertex_ai_index_endpoint_id = "projects/PROJECT/locations/REGION/indexEndpoints/ENDPOINT_ID"
